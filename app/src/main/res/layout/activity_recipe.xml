<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header / Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resep Sehat"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btnRegenerate"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Card Info BMR -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#EAF6EB"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvRecipeGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hai, User! 🌱"
                        android:textColor="#163317"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvRecipeSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="16dp"
                        android:text="Rekomendasi menu berdasarkan BMR kamu hari ini."
                        android:textColor="#3A5F3B"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@+id/ivMascot"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvRecipeGreeting" />

                    <ImageView
                        android:id="@+id/ivMascot"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/logo"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Filter Kategori -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnDiet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_green"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="Diet"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_orange"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Tinggi Protein"
                    android:textColor="#E65100"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSimple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_blue"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Simple &amp; Murah"
                    android:textColor="#1565C0"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Menu Sarapan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="🍳 Sarapan"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSarapan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#F9FBF9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <!-- REVISI: Tambah ID ivSarapan -->
                    <ImageView
                        android:id="@+id/ivSarapan"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvTitleSarapan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oatmeal Pisang"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvKcalSarapan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="320 kcal"
                            android:textColor="#4CAF50"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvDescSarapan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oatmeal dengan madu dan pisang."
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Makan Siang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="🍱 Makan Siang"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMakanSiang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#F9FBF9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <!-- REVISI: Tambah ID ivSiang -->
                    <ImageView
                        android:id="@+id/ivSiang"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvTitleSiang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ayam Panggang"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvKcalSiang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="450 kcal"
                            android:textColor="#4CAF50"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvDescSiang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ayam panggang dengan nasi merah."
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Makan Malam -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="🍲 Makan Malam"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMakanMalam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#F9FBF9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <!-- REVISI: Tambah ID ivMalam -->
                    <ImageView
                        android:id="@+id/ivMalam"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvTitleMalam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sup Ayam"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvKcalMalam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="390 kcal"
                            android:textColor="#4CAF50"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvDescMalam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sup ayam bening dengan sayuran."
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Tombol Regenerate -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRegenerate"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="16dp"
        android:background="@drawable/rounded_button_green"
        android:text="Buat Resep Lagi ↻"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>